{
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> i32 {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Create a main function"
  },
  "Function Definition": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}) -> ${3:ret_type} {",
      "\t$0",
      "}"
    ],
    "description": "Define a new function"
  },
  "Module Declaration": {
    "prefix": "module",
    "body": "module ${1:name}",
    "description": "Declare the current module"
  },
  "Import Module": {
    "prefix": "import",
    "body": "import ${1:module}",
    "description": "Import a module"
  },
  "Struct Type Declaration": {
    "prefix": "struct",
    "body": [
      "${1:Name} {",
      "\t${2:field}: ${3:type},",
      "\t$0",
      "}"
    ],
    "description": "Define a keyword-less struct type"
  },
  "Sum Type Declaration": {
    "prefix": "sum",
    "body": [
      "${1:Name} {",
      "\t${2:Variant},",
      "\t${3:VariantWithValue}(${4:type}),",
      "\t$0",
      "}"
    ],
    "description": "Define a keyword-less sum type"
  },
  "Match Statement": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:Pattern} => $0,",
      "}"
    ],
    "description": "Match statement"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "Loop Expression": {
    "prefix": "loop",
    "body": [
      "loop {",
      "\t$0",
      "\tif ${1:done} { break }",
      "}"
    ],
    "description": "Create a loop expression with its break condition"
  },
  "Lambda Expression": {
    "prefix": "lambda",
    "body": [
      "fn ${1:x} {",
      "\t$0",
      "}"
    ],
    "description": "Create an inline lambda"
  },
  "Arena Block": {
    "prefix": "arena",
    "body": [
      "arena {",
      "\t$0",
      "}"
    ],
    "description": "Create an arena allocation scope"
  },
  "Task Group": {
    "prefix": "task_group",
    "body": [
      "task_group {",
      "\t$0",
      "}"
    ],
    "description": "Create a structured task scope"
  },
  "Array map": {
    "prefix": "map",
    "body": "map(${1:func})",
    "description": "Array map (fused pipeline)"
  },
  "Array par_map": {
    "prefix": "par_map",
    "body": "par_map(${1:func})",
    "description": "Array parallel map"
  },
  "Array where": {
    "prefix": "where",
    "body": "where(.${1:field})",
    "description": "Array filter (where)"
  },
  "Array reduce": {
    "prefix": "reduce",
    "body": "reduce(${1:init}, ${2:func})",
    "description": "Array reduce"
  },
  "Array scan": {
    "prefix": "scan",
    "body": "scan(${1:init}, ${2:func})",
    "description": "Array scan"
  },
  "Array partition": {
    "prefix": "partition",
    "body": "partition(${1:predicate})",
    "description": "Partition scalar elements with a predicate"
  },
  "Array group_by": {
    "prefix": "group_by",
    "body": "group_by(.${1:key}).sum(.${2:value})",
    "description": "Group by a field and aggregate (group_by cannot stand alone)"
  },
  "Array grouped aggregates": {
    "prefix": "agg",
    "body": "group_by(.${1:key}).agg(sum(.${2:value}), max(.${3:value}), count())",
    "description": "Group by a field and compute multiple aggregates in one pass"
  },
  "Array sort": {
    "prefix": "sort",
    "body": "sort()",
    "description": "Array sort"
  },
  "Array sort_by_key": {
    "prefix": "sort_by_key",
    "body": "sort_by_key(${1:key_func})",
    "description": "Sort primitive elements by a key function"
  },
  "Array chunks": {
    "prefix": "chunks",
    "body": "chunks(${1:size})",
    "description": "Array chunks"
  },
  "Array materialize": {
    "prefix": "to_array",
    "body": "to_array()",
    "description": "Materialize a pipeline into an owned array"
  },
  "Array map_into": {
    "prefix": "map_into",
    "body": "map_into(${1:destination})",
    "description": "Write a length-preserving pipeline into caller storage"
  },
  "Array to_soa": {
    "prefix": "to_soa",
    "body": "to_soa()",
    "description": "Transpose an array of structs into arena-backed column storage"
  },
  "Array dict_encode": {
    "prefix": "dict_encode",
    "body": "dict_encode(.${1:key})",
    "description": "Dictionary-encode a string key for repeated group_by operations"
  },
  "Array zip": {
    "prefix": "zip",
    "body": "zip(${1:first}, ${2:second})",
    "description": "Start a lazy equal-length multi-source pipeline"
  },
  "Array sum": {
    "prefix": "sum",
    "body": "sum()",
    "description": "Array sum reduction"
  },
  "Array min": {
    "prefix": "min",
    "body": "min()",
    "description": "Array min reduction"
  },
  "Array max": {
    "prefix": "max",
    "body": "max()",
    "description": "Array max reduction"
  },
  "Array count": {
    "prefix": "count",
    "body": "count()",
    "description": "Array count reduction"
  },
  "Array any": {
    "prefix": "any",
    "body": "any(${1:predicate})",
    "description": "Test whether a predicate holds for any element"
  },
  "Array all": {
    "prefix": "all",
    "body": "all(${1:predicate})",
    "description": "Test whether a predicate holds for all elements"
  },
  "Array dot": {
    "prefix": "dot",
    "body": "dot(${1:other_array})",
    "description": "Array dot product reduction"
  },
  "Array builder": {
    "prefix": "array_builder",
    "body": [
      "mut ${1:builder}: array_builder<${2:i64}> := array_builder()",
      "${1:builder}.push(${3:value})",
      "${4:values} := ${1:builder}.build()"
    ],
    "description": "Grow and freeze an owned array"
  },
  "Compile regex": {
    "prefix": "regex.compile",
    "body": "${1:re} := regex.compile(\"${2:pattern}\")?",
    "description": "Compile a std.regex pattern into an owned regex handle"
  },
  "Test regex match": {
    "prefix": "regex.is_match",
    "body": "${1:re}.is_match(${2:text})",
    "description": "Test whether a compiled regex matches text"
  },
  "Find regex match": {
    "prefix": "regex.find",
    "body": [
      "match ${1:re}.find(${2:text}) {",
      "\tSome(${3:m}) => $0,",
      "\tNone => ${4:()},",
      "}"
    ],
    "description": "Find the first regex match as half-open UTF-8 byte offsets"
  },
  "Find regex match at offset": {
    "prefix": "regex.find_at",
    "body": [
      "match ${1:re}.find_at(${2:text}, ${3:start}) {",
      "\tSome(${4:m}) => $0,",
      "\tNone => ${5:()},",
      "}"
    ],
    "description": "Find a regex match at or after a validated UTF-8 byte offset"
  }
}
