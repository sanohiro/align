{
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> i32 {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Create a main function"
  },
  "Function Definition": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}) -> ${3:ret_type} {",
      "\t$0",
      "}"
    ],
    "description": "Define a new function"
  },
  "Struct Definition": {
    "prefix": "struct",
    "body": [
      "${1:Name} {",
      "\t${2:field}: ${3:type},",
      "\t$0",
      "}"
    ],
    "description": "Define a new struct"
  },
  "Match Statement": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:Pattern} => $0,",
      "}"
    ],
    "description": "Match statement"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "Task Group": {
    "prefix": "task_group",
    "body": [
      "task_group {",
      "\t$0",
      "}"
    ],
    "description": "Spawn a task group"
  },
