{
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> i32 {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Create a main function"
  },
  "Function Definition": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}) -> ${3:ret_type} {",
      "\t$0",
      "}"
    ],
    "description": "Define a new function"
  },
  "Module Declaration": {
    "prefix": "module",
    "body": "module ${1:name}",
    "description": "Declare the current module"
  },
  "Import Module": {
    "prefix": "import",
    "body": "import ${1:module}",
    "description": "Import a module"
  },
  "Struct Type Declaration": {
    "prefix": "struct",
    "body": [
      "${1:Name} {",
      "\t${2:field}: ${3:type},",
      "\t$0",
      "}"
    ],
    "description": "Define a keyword-less struct type"
  },
  "Sum Type Declaration": {
    "prefix": "sum",
    "body": [
      "${1:Name} {",
      "\t${2:Variant},",
      "\t${3:VariantWithValue}(${4:type}),",
      "\t$0",
      "}"
    ],
    "description": "Define a keyword-less sum type"
  },
  "Match Statement": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:Pattern} => $0,",
      "}"
    ],
    "description": "Match statement"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "Loop Expression": {
    "prefix": "loop",
    "body": [
      "loop {",
      "\t$0",
      "\tif ${1:done} { break }",
      "}"
    ],
    "description": "Create a loop expression with its break condition"
  },
  "Lambda Expression": {
    "prefix": "lambda",
    "body": [
      "fn ${1:x} {",
      "\t$0",
      "}"
    ],
    "description": "Create an inline lambda"
  },
  "Arena Block": {
    "prefix": "arena",
    "body": [
      "arena {",
      "\t$0",
      "}"
    ],
    "description": "Create an arena allocation scope"
  },
  "Task Group": {
    "prefix": "task_group",
    "body": [
      "task_group {",
      "\t$0",
      "}"
    ],
    "description": "Create a structured task scope"
  },
  "Array map": {
    "prefix": "map",
    "body": "map(${1:func})",
    "description": "Array map (fused pipeline)"
  },
  "Array par_map": {
    "prefix": "par_map",
    "body": "par_map(${1:func})",
    "description": "Array parallel map"
  },
  "Array where": {
    "prefix": "where",
    "body": "where(.${1:field})",
    "description": "Array filter (where)"
  },
  "Array reduce": {
    "prefix": "reduce",
    "body": "reduce(${1:init}, ${2:func})",
    "description": "Array reduce"
  },
  "Array scan": {
    "prefix": "scan",
    "body": "scan(${1:init}, ${2:func})",
    "description": "Array scan"
  },
  "Array partition": {
    "prefix": "partition",
    "body": "partition(.${1:field})",
    "description": "Array partition"
  },
  "Array group_by": {
    "prefix": "group_by",
    "body": "group_by(.${1:field})",
    "description": "Array group_by"
  },
  "Array sort": {
    "prefix": "sort",
    "body": "sort()",
    "description": "Array sort"
  },
  "Array sort_by_key": {
    "prefix": "sort_by_key",
    "body": "sort_by_key(.${1:field})",
    "description": "Array sort by key"
  },
  "Array chunks": {
    "prefix": "chunks",
    "body": "chunks(${1:size})",
