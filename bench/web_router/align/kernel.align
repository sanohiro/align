    pkg.web.get("/api/g0/res5", h),
    pkg.web.get("/api/g0/res5/:id", h),
    pkg.web.get("/api/g0/res6", h),
    pkg.web.get("/api/g0/res6/:id", h),
    pkg.web.get("/api/g0/res7", h),
    pkg.web.get("/api/g0/res7/:id", h),
    pkg.web.get("/api/g1/res0", h),
    pkg.web.get("/api/g1/res0/:id", h),
    pkg.web.get("/api/g1/res1", h),
    pkg.web.get("/api/g1/res1/:id", h),
    pkg.web.get("/api/g1/res2", h),
    pkg.web.get("/api/g1/res2/:id", h),
    pkg.web.get("/api/g1/res3", h),
    pkg.web.get("/api/g1/res3/:id", h),
    pkg.web.get("/api/g1/res4", h),
    pkg.web.get("/api/g1/res4/:id", h),
    pkg.web.get("/api/g1/res5", h),
    pkg.web.get("/api/g1/res5/:id", h),
    pkg.web.get("/api/g1/res6", h),
    pkg.web.get("/api/g1/res6/:id", h),
    pkg.web.get("/api/g1/res7", h),
    pkg.web.get("/api/g1/res7/:id", h),
    pkg.web.get("/api/g2/res0", h),
    pkg.web.get("/api/g2/res0/:id", h),
    pkg.web.get("/api/g2/res1", h),
    pkg.web.get("/api/g2/res1/:id", h),
    pkg.web.get("/api/g2/res2", h),
    pkg.web.get("/api/g2/res2/:id", h),
    pkg.web.get("/api/g2/res3", h),
    pkg.web.get("/api/g2/res3/:id", h),
    pkg.web.get("/api/g2/res4", h),
    pkg.web.get("/api/g2/res4/:id", h),
    pkg.web.get("/api/g2/res5", h),
    pkg.web.get("/api/g2/res5/:id", h),
    pkg.web.get("/api/g2/res6", h),
    pkg.web.get("/api/g2/res6/:id", h),
    pkg.web.get("/api/g2/res7", h),
    pkg.web.get("/api/g2/res7/:id", h),
    pkg.web.get("/api/g3/res0", h),
    pkg.web.get("/api/g3/res0/:id", h),
    pkg.web.get("/api/g3/res1", h),
    pkg.web.get("/api/g3/res1/:id", h),
    pkg.web.get("/api/g3/res2", h),
    pkg.web.get("/api/g3/res2/:id", h),
    pkg.web.get("/api/g3/res3", h),
    pkg.web.get("/api/g3/res3/:id", h),
    pkg.web.get("/api/g3/res4", h),
    pkg.web.get("/api/g3/res4/:id", h),
    pkg.web.get("/api/g3/res5", h),
    pkg.web.get("/api/g3/res5/:id", h),
    pkg.web.get("/api/g3/res6", h),
    pkg.web.get("/api/g3/res6/:id", h),
    pkg.web.get("/api/g3/res7", h),
    pkg.web.get("/api/g3/res7/:id", h),
    pkg.web.get("/api/g4/res0", h),
    pkg.web.get("/api/g4/res0/:id", h),
    pkg.web.get("/api/g4/res1", h),
    pkg.web.get("/api/g4/res1/:id", h),
    pkg.web.get("/api/g4/res2", h),
    pkg.web.get("/api/g4/res2/:id", h),
    pkg.web.get("/api/g4/res3", h),
    pkg.web.get("/api/g4/res3/:id", h),
    pkg.web.get("/api/g4/res4", h),
    pkg.web.get("/api/g4/res4/:id", h),
    pkg.web.get("/api/g4/res5", h),
    pkg.web.get("/api/g4/res5/:id", h),
    pkg.web.get("/api/g4/res6", h),
    pkg.web.get("/api/g4/res6/:id", h),
    pkg.web.get("/api/g4/res7", h),
    pkg.web.get("/api/g4/res7/:id", h),
    pkg.web.get("/api/g5/res0", h),
    pkg.web.get("/api/g5/res0/:id", h),
    pkg.web.get("/api/g5/res1", h),
    pkg.web.get("/api/g5/res1/:id", h),
    pkg.web.get("/api/g5/res2", h),
    pkg.web.get("/api/g5/res2/:id", h),
    pkg.web.get("/api/g5/res3", h),
    pkg.web.get("/api/g5/res3/:id", h),
    pkg.web.get("/api/g5/res4", h),
    pkg.web.get("/api/g5/res4/:id", h),
    pkg.web.get("/api/g5/res5", h),
    pkg.web.get("/api/g5/res5/:id", h),
    pkg.web.get("/api/g5/res6", h),
    pkg.web.get("/api/g5/res6/:id", h),
    pkg.web.get("/api/g5/res7", h),
    pkg.web.get("/api/g5/res7/:id", h),
    pkg.web.get("/api/g6/res0", h),
    pkg.web.get("/api/g6/res0/:id", h),
    pkg.web.get("/api/g6/res1", h),
    pkg.web.get("/api/g6/res1/:id", h),
    pkg.web.get("/api/g6/res2", h),
    pkg.web.get("/api/g6/res2/:id", h),
    pkg.web.get("/api/g6/res3", h),
    pkg.web.get("/api/g6/res3/:id", h),
    pkg.web.get("/api/g6/res4", h),
    pkg.web.get("/api/g6/res4/:id", h),
    pkg.web.get("/api/g6/res5", h),
    pkg.web.get("/api/g6/res5/:id", h),
    pkg.web.get("/api/g6/res6", h),
    pkg.web.get("/api/g6/res6/:id", h),
    pkg.web.get("/api/g6/res7", h),
    pkg.web.get("/api/g6/res7/:id", h),
    pkg.web.get("/api/g7/res0", h),
    pkg.web.get("/api/g7/res0/:id", h),
    pkg.web.get("/api/g7/res1", h),
    pkg.web.get("/api/g7/res1/:id", h),
    pkg.web.get("/api/g7/res2", h),
    pkg.web.get("/api/g7/res2/:id", h),
    pkg.web.get("/api/g7/res3", h),
    pkg.web.get("/api/g7/res3/:id", h),
    pkg.web.get("/api/g7/res4", h),
    pkg.web.get("/api/g7/res4/:id", h),
    pkg.web.get("/api/g7/res5", h),
    pkg.web.get("/api/g7/res5/:id", h),
    pkg.web.get("/api/g7/res6", h),
    pkg.web.get("/api/g7/res6/:id", h),
    pkg.web.get("/api/g7/res7", h),
    pkg.web.get("/api/g7/res7/:id", h),
  ]
  paths := ["/api/g0/res0", "/api/g7/res7/42", "/api/zz/nope/42", "/api/zz/nope/42"]
  path := path_of(paths, shape)
  tree := pkg.web.bench.build(routes)
  mut acc := 0
  mut i := 0
  loop {
    if i >= n { break acc }
    acc = acc + pkg.web.bench.dispatch(routes, tree[..], "GET", path)
    i = i + 1
  }
}
