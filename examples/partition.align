// `partition(p)` splits a pipeline's surviving elements into two owned arrays — those
// satisfying the predicate, then the rest — in a single fused loop (no intermediate array).
// The result is a tuple `(array<T>, array<T>)`, destructured into the two halves.
fn is_even(x: i64) -> bool = x % 2 == 0

fn main() -> Result<(), Error> {
  (evens, odds) := [1, 2, 3, 4, 5].partition(is_even)
  print(evens.sum())   // 2 + 4 = 6
  print(odds.sum())    // 1 + 3 + 5 = 9
  return Ok(())
}
