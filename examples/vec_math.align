// Element-wise float-vector math (M6). The unary float ops — `sqrt`, `abs`, `floor`, `ceil`,
// `round`, `trunc` — apply lane-wise to a `vecN<f32>`/`vecN<f64>` (the same surface as the scalar
// versions), each lowering to the LLVM vector intrinsic (e.g. `llvm.sqrt.v4f32`) — one SIMD
// instruction, not a per-lane loop.

fn main() -> i32 {
  v: vec4<f32> := [1.0, 4.0, 9.0, 16.0]
  r := v.sqrt()                            // [1, 2, 3, 4]
  return (r[0] + r[1] + r[2] + r[3]) as i32 // 10
}
