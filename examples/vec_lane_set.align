// Lane assignment (M6). `v[i] = x` writes a single lane `i` (a constant in 0..N) of a `mut`
// vector to the scalar `x` — the write counterpart of the lane read `v[i]`. A vector is a register
// value, so this updates the vector in place (`v = insertelement(v, x, i)`).

fn main() -> i32 {
  mut v: vec4<i32> := [10, 20, 30, 40]
  v[1] = 99
  v[3] = 1
  return v[0] + v[1] + v[2] + v[3]   // 10 + 99 + 30 + 1 = 140
}
