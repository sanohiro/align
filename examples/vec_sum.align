// Horizontal sum reduction over a vector (draft.md §9). `v.sum()` adds all lanes of a `vecN<T>` to
// the element scalar — the unmasked sibling of `v.sum_where(mask)`, and the same surface as the
// array reduction `arr.sum()`.

fn main() -> i32 {
  v: vec4<i32> := [10, 20, 30, 40]
  return v.sum()   // 100
}
